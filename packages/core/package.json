{
  "name": "@k1low/kakitori",
  "version": "0.14.0",
  "description": "A handwriting practice library for kanji, kana, and numbers — per-stroke tome / hane / harai judgment, composable practice problems, and a paper-style multi-block layout",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/k1LoW/kakitori",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./block": {
      "types": "./dist/block/index.d.ts",
      "import": "./dist/block/index.js",
      "require": "./dist/block/index.cjs"
    },
    "./page": {
      "types": "./dist/page/index.d.ts",
      "import": "./dist/page/index.js",
      "require": "./dist/page/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hanzi-writer": "^3.0.0"
  },
  "dependencies": {
    "@k1low/kakitori-data": "workspace:^"
  },
  "devDependencies": {
    "hanzi-writer": "3.7.3",
    "happy-dom": "20.9.0",
    "tsdown": "0.12.5",
    "typescript": "5.8.3",
    "vitest": "3.1.3"
  }
}
